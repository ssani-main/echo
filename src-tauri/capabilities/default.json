{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window — core APIs plus permission to spawn the bundled Node sidecar that runs the Echo backend.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/node",
          "sidecar": true
        }
      ]
    }
  ]
}
