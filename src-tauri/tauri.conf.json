{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Echo",
  "version": "0.1.0",
  "identifier": "com.echo.reader",
  "build": {
    "frontendDist": "dist-shell",
    "devUrl": "http://localhost:8000"
  },
  "app": {
    "windows": [
      {
        "title": "Echo",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "url": "loading.html"
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "resources": {
      "../server.js": "server.js",
      "../digest.js": "digest.js",
      "../providers.js": "providers.js",
      "../transcript.js": "transcript.js",
      "../whisper.js": "whisper.js",
      "../whisperModel.js": "whisperModel.js",
      "../vendor/whisper/linux-x64/whisper-cli": "vendor/whisper/linux-x64/whisper-cli",
      "../vendor/whisper/linux-x64/libwhisper.so.1": "vendor/whisper/linux-x64/libwhisper.so.1",
      "../vendor/whisper/linux-x64/libggml.so.0": "vendor/whisper/linux-x64/libggml.so.0",
      "../vendor/whisper/linux-x64/libggml-base.so.0": "vendor/whisper/linux-x64/libggml-base.so.0",
      "../vendor/whisper/linux-x64/libggml-cpu-x64.so": "vendor/whisper/linux-x64/libggml-cpu-x64.so",
      "../vendor/whisper/linux-x64/libggml-cpu-haswell.so": "vendor/whisper/linux-x64/libggml-cpu-haswell.so",
      "../frames.js": "frames.js",
      "../store.js": "store.js",
      "../markdown.js": "markdown.js",
      "../vault.js": "vault.js",
      "../playlistJob.js": "playlistJob.js",
      "../sanitize.js": "sanitize.js",
      "../discovery.js": "discovery.js",
      "../usagelog.js": "usagelog.js",
      "../websearch.js": "websearch.js",
      "../sharepage.js": "sharepage.js",
      "../package.json": "package.json",
      "../public": "public",
      "dist-deps/node_modules": "node_modules"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
