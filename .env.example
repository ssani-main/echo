# Echo — environment variables
#
# Copy to .env for local use, or set these directly in your hosting platform.
# None are required to run locally (`npm start`) — every default below
# preserves current local/desktop behaviour.

# --- Mode -------------------------------------------------------------------

# 'local' (default) or 'web'. 'web' enables BYOK (bring-your-own-key) mode,
# rate limiting, payload/transcript size caps, and disables server-side
# library/search persistence. Only set this to 'web' for a hosted deployment.
ECHO_MODE=local

# Interface to bind to. Defaults to 127.0.0.1 (not reachable from the
# network) for safety in local/desktop use. Set to 0.0.0.0 to accept
# connections from outside the container/host (needed behind a reverse proxy).
ECHO_HOST=127.0.0.1

# Port to listen on.
PORT=8000

# --- AI provider --------------------------------------------------------

# Which summarization provider to use: unset/'cli' (default, wraps the local
# `claude` CLI) or 'api' (talks directly to the Anthropic API via
# @anthropic-ai/sdk). In ECHO_MODE=web, requests always use ApiKeyProvider via
# the per-request X-Echo-Api-Key header regardless of this setting.
ECHO_PROVIDER=cli

# Fallback Anthropic API key used by ApiKeyProvider when no per-request key
# is supplied (e.g. local testing of the API provider path). Never required
# in ECHO_MODE=web — hosted requests must bring their own key.
ANTHROPIC_API_KEY=

# --- Web-mode abuse / cost guards (no-ops unless ECHO_MODE=web) -------------

# Max transcript length (characters) accepted before rejecting the request.
ECHO_MAX_TRANSCRIPT_CHARS=200000

# Max text/segments payload size (characters) accepted by AI endpoints.
ECHO_MAX_AI_PAYLOAD_CHARS=200000

# --- Storage / models ---------------------------------------------------

# Path to the SQLite library database file. Ignored entirely in ECHO_MODE=web
# (server-side library routes are disabled; the browser persists locally).
ECHO_DB_PATH=./data/library.db
